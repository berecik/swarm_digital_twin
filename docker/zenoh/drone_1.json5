{
  "mode": "peer",
  "metadata": {
    "author": "beret@hipisi.org.pl",
    "company": "Marysia Software Limited",
    "domain": "app.marysia.drone",
    "website": "https://marysia.app"
  },
  "connect": {
    "endpoints": ["tcp/10.10.1.11:7447"]
  },
  "scouting": {
    "multicast": { "enabled": false }
  },
  "timestamping": {
    "enabled": { "egress": true, "ingress": true }
  },
  "namespace": "/swarm/drone_1",
  "allow": {
    "publications": [
      "/swarm/drone_1/state",
      "/swarm/drone_1/consensus/propose",
      "/swarm/drone_1/consensus/raft_tx"
    ],
    "subscriptions": [
      "/swarm/*/state",
      "/swarm/*/consensus/raft_tx",
      "/fmu/in/offboard_control_mode",
      "/fmu/in/trajectory_setpoint",
      "/fmu/in/vehicle_command",
      "/fmu/out/vehicle_status",
      "/fmu/out/vehicle_odometry"
    ]
  },
  "deny": {
    "publications": ["/**"],
    "subscriptions": [
      "/rosout",
      "/parameter_events",
      "/tf",
      "/tf_static",
      "/camera/**",
      "/lidar/**",
      "/image/**",
      "/diagnostics",
      "/clock",
      "/joint_states"
    ]
  }
}
