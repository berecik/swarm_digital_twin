<model>
  <name>IRS-4 Quadrotor</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <author>
    <name>beret</name>
    <email>beret@hipisi.org.pl</email>
  </author>
  <description>
    IRS-4 quadrotor UAV for Swarm Digital Twin.
    Paper: Valencia et al. (2025), Section 3.2.
    Platform used at Carolina Park and EPN campus (Quito, 2800m MSL).
    Mass: 1.8 kg, arm length: 0.22 m, symmetric X-frame.
    Compatible with ArduPilot SITL Copter.
  </description>
</model>
